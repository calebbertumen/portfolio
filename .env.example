# -----------------------------------------------------------------------------
# Public site configuration (safe to commit this file — no real secrets here)
# -----------------------------------------------------------------------------
# Copy to `.env.local` and replace with your values. `.env.local` is gitignored.
#
# These variables are exposed in the browser (NEXT_PUBLIC_*). Use them only for
# information you are happy showing on the live portfolio (same as any public site).
#
# After changing values, restart `npm run dev`. On Vercel: Project → Settings →
# Environment Variables → add each key for Production (and Preview if you want).
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SITE_EMAIL=you@example.com
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/your-profile/
NEXT_PUBLIC_LINKEDIN_DISPLAY=linkedin.com/in/your-profile
NEXT_PUBLIC_GITHUB_URL=https://github.com/yourusername
NEXT_PUBLIC_GITHUB_DISPLAY=github.com/yourusername

# Path to a PDF under /public (omit the file from git if the PDF contains private info)
NEXT_PUBLIC_RESUME_PATH=/resume.pdf

# -----------------------------------------------------------------------------
# Future: server-only secrets (no NEXT_PUBLIC_ prefix — never exposed to the browser)
# -----------------------------------------------------------------------------
# CMS_TOKEN=
# DATABASE_URL=
# STRIPE_SECRET_KEY=
